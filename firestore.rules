rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: quotes
    // Document ID: auto-generated
    // Fields:
    //   - content: string (required, max 1000 chars)
    //   - author: string (required, max 100 chars)
    //   - source: string (optional, max 100 chars)
    //   - category: string (optional, max 50 chars)
    //   - createdBy: string (required, UID or 'system')
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - displayName: string
    //   - email: string
    //   - photoURL: string
    //   - role: string ('user' or 'admin')
    //
    // Collection: users/{userId}/favorites
    // Document ID: quoteId
    // Fields:
    //   - quoteId: string
    //   - createdAt: timestamp
    //
    // Collection: users/{userId}/reflections
    // Document ID: auto-generated
    // Fields:
    //   - quoteId: string
    //   - content: string (max 2000 chars)
    //   - createdAt: timestamp
    //
    // Collection: users/{userId}/heartbeats
    // Document ID: quoteId
    // Fields:
    //   - quoteId: string
    //   - count: number
    //   - lastLikedAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "s1479843569@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidQuote(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 100 &&
             (!('source' in data) || (data.source is string && data.source.size() <= 100)) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 50));
    }

    function isValidReflection(data) {
      return data.quoteId is string &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000;
    }

    function isValidHeartbeat(data) {
      return data.quoteId is string &&
             data.count is number && data.count >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if isAdmin(); // Only admins can change roles or other user metadata
    }

    match /quotes/{quoteId} {
      allow read: if true; // Quotes are public
      allow create: if isAuthenticated() && isValidQuote(request.resource.data) && (request.resource.data.createdBy == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isAdmin()) && isValidQuote(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /users/{userId}/favorites/{quoteId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/reflections/{reflectionId} {
      allow read, write: if isOwner(userId) && isValidReflection(request.resource.data);
    }

    match /users/{userId}/heartbeats/{quoteId} {
      allow read, write: if isOwner(userId) && isValidHeartbeat(request.resource.data);
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
