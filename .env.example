# Browser-side Supabase client
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"
VITE_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
VITE_PUBLIC_SUPABASE_ANON_KEY="your-public-anon-key"
VITE_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# Server-side Supabase access for Vercel Functions
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_SECRET_KEY="sb_secret_xxx"
SUPABASE_JWT_SECRET="your-jwt-secret"

# Direct Postgres connections
POSTGRES_URL="postgres://user:password@host:6543/postgres?sslmode=require"
POSTGRES_PRISMA_URL="postgres://user:password@host:6543/postgres?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://user:password@host:5432/postgres?sslmode=require"

# Supabase Auth notes
# 1. Site URL should point to your deployed frontend origin.
# 2. Password reset redirectTo should include:
#    http://localhost:3000/auth/reset-password
#    https://your-domain.com/auth/reset-password
